            <TextBlock 
                Margin="10,20,0,4"
                x:Name="ContentText"
                Grid.Row="0"
                Grid.Column="1"
                Grid.ColumnSpan="3"
                VerticalAlignment="Center"
                TextWrapping="Wrap"
                Foreground="{StaticResource GrayForegroundBrush}"
                FontSize="16"/>
            <TextBlock
                Grid.Column="1"
                Grid.Row="1"
                Grid.ColumnSpan="3"
                x:Name="Warning"
                Margin="10,0,0,5"
                VerticalAlignment="Center"
                Foreground="{StaticResource AccentBrushDark}"
                FontSize="16"
                TextAlignment="Right"/>
            <Button
                Margin="0,0,4,0"
                Style="{StaticResource AccentedButtonStyle}"
                Grid.Row="2"
                Grid.Column="2"
                FontWeight="SemiBold"
                FontSize="14"
                Command="{StaticResource Confirm}"
                CommandParameter="{x:Reference Name=Dialog}"
                Content="Yes"/>
            <Button
                Style="{StaticResource AccentedButtonStyle}"
                Margin="4,0,0,0"
                Grid.Row="2"
                Grid.Column="3"
                FontSize="14"
                FontWeight="SemiBold"
                Command="{StaticResource Deny}"
                CommandParameter="{x:Reference Name=Dialog}"
                Content="No"/>
        </Grid>
    </Grid>
</Window>
